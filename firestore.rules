rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'larambla.workspace@gmail.com';
    }

    match /dishes/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /settings/{doc} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
